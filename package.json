{
  "name": "mooncellar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=ExperimentalWarning next dev",
    "build": "NODE_OPTIONS=--disable-warning=ExperimentalWarning next build",
    "start": "NODE_OPTIONS=--disable-warning=ExperimentalWarning next start -p 3111",
    "lint": "eslint src --ext ts,tsx,js,jsx --report-unused-disable-directives --max-warnings 10",
    "lint:fix": "eslint src --ext js,jsx,ts,tsx --fix",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,css,scss,html}'",
    "check:schemas": "bun run ${MOONCELLAR_SERVER_PATH:-../MoonCellar-Server}/scripts/check-schema-parity.ts",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "bun run lint"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "bun run lint"
    ]
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.8.2",
    "@hookform/resolvers": "^5.4.0",
    "@types/react-virtualized": "^9.22.3",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "interweave": "^13.1.1",
    "jwt-decode": "^4.0.0",
    "maxmind": "^5.0.6",
    "next": "^16.3.0-preview.6",
    "query-string": "^9.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-markdown": "^10.1.0",
    "react-resize-detector": "^12.3.0",
    "react-scan": "^0.5.7",
    "react-spinners": "^0.17.0",
    "react-virtualized": "^9.22.6",
    "sass": "^1.101.0",
    "scss": "^0.2.4",
    "typescript-eslint": "^8.64.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@iconify/react": "^6.0.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "interweave-ssr": "^2.0.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript": "5.9.3"
  }
}
